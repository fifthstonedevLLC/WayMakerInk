// === WayMaker Ink — Prep Metadata (build folder name, file name, and polished HTML) ===
// Mode: Run Once for Each Item  |  Language: JavaScript
const b = $json.body ?? $json;

const firstName = (b.firstName || "").trim();
const lastName = (b.lastName || "").trim();
const dob = (b.dob || "").trim(); // yyyy-mm-dd

// --- Folder naming convention: {FirstInitial}{LastName}_{DOB} ---
const firstInitial = firstName.charAt(0).toUpperCase();
const lastInitial = lastName.charAt(0).toUpperCase();
const initials = `${firstInitial}${lastInitial}`;
const lastNameClean = lastName
  .replace(/\s+/g, "")
  .replace(/[^A-Za-z0-9-]/g, "");
const lastNameKey = lastNameClean.toUpperCase();
const folderName = `${firstInitial}${lastNameKey}_${dob}`;

const fullName = `${firstName} ${lastName}`.trim();
const formType = b.formType || "waiver";
const isPiercing = formType === "piercing-waiver";
const signDate = b.signDate || new Date().toISOString().slice(0, 10);
const signedAt = b.signedAt || new Date().toISOString();
const fileName = `${folderName}_${formType}_${signDate}.pdf`;

// --- Address: combine the separated form fields into a single line ---
// Piercing form sends `address` (street) + `cityStateZip`. Tattoo form sends a
// single `address`. Legacy city/state/zip split fields are still supported.
const addressLine = [
  b.address,
  b.cityStateZip,
  b.city,
  [b.state, b.zip].map((p) => (p || "").trim()).filter(Boolean).join(" "),
]
  .map((part) => (part || "").trim())
  .filter(Boolean)
  .join(", ");

// Guardian address is collected as separate street/city/state/zip fields.
// Older submissions sent the whole address in `guardianAddress`; that still
// works here because the extra fields are simply empty and filtered out.
const guardianAddressLine = [
  b.guardianAddress,
  b.guardianCity,
  [b.guardianState, b.guardianZip].map((p) => (p || "").trim()).filter(Boolean).join(" "),
]
  .map((part) => (part || "").trim())
  .filter(Boolean)
  .join(", ");

// Pretty date helper
const fmt = (iso) => {
  if (!iso) return "";
  const d = new Date(iso.length === 10 ? iso + "T00:00:00" : iso);
  return isNaN(d)
    ? iso
    : d.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      });
};

// Label/value cell for the info grids. Renders an em dash for empty values.
const cell = (label, value, full = false) =>
  `<div class="cell${full ? " full" : ""}"><span class="lbl">${label}</span><span class="val">${
    (value ?? "").toString().trim() || "—"
  }</span></div>`;

// Staff member: piercing forms send `piercerUsed`, tattoo forms `artistUsed`.
const staffLabel = isPiercing ? "Piercer" : "Artist";
const staffName = isPiercing ? b.piercerUsed : b.artistUsed;

// Client Information cells differ per form: the piercing form has Age and no
// Email / Driver's License; the tattoo form has Email / License and no Age.
const clientCells = (isPiercing
  ? [
      cell("Name", fullName),
      cell("Date of Birth", fmt(dob)),
      cell("Age", b.age),
      cell("Phone", b.phone),
      cell(staffLabel, staffName),
      cell("Address", addressLine, true),
    ]
  : [
      cell("Name", fullName),
      cell("Date of Birth", fmt(dob)),
      cell("Phone", b.phone),
      cell("Email", b.email),
      cell("Driver's License / ID", b.license),
      cell(staffLabel, staffName),
      cell("Address", addressLine, true),
    ]
).join("");

// Piercing-only sections: procedure details and health declarations.
const procedureSection = isPiercing
  ? `
  <h2>Piercing Details</h2>
  <div class="grid">
    ${cell("Body Location", b.bodyLocation)}
    ${cell("Jewelry Type", b.jewelryType)}
    ${cell("Date of Procedure", b.procedureDate ? fmt(b.procedureDate) : "")}
    ${cell("Known Conditions", b.knownConditions, true)}
  </div>`
  : "";

// Provisions
const provisions = Array.isArray(b.provisions) ? b.provisions : [];
const provisionRows = provisions
  .map(
    (p) => `
      <li class="prov">
        <span class="prov-num">${p.index}</span>
        <span class="prov-text">${p.text}</span>
        <span class="prov-badge ${p.initialed ? "ok" : "no"}">${p.initialed ? initials : "—"}</span>
      </li>`,
  )
  .join("");

const consentLine = b.electronicConsent
  ? "Signer consented to conduct this transaction electronically (E-SIGN / UETA)."
  : "Electronic-signature consent was not recorded.";
const guardianConsent = b.guardianElectronicConsent
  ? `<div class="consent">Parent/Guardian consented to sign electronically.</div>`
  : "";

// --- Is the piercee a minor? -------------------------------------------------
// Belt-and-suspenders: the guardian section renders if EITHER a guardian
// actually signed OR the client is determined to be under 18. Age is taken
// from DOB (most reliable, computed as of the signing date) and falls back to
// the explicit `minorAge` / `age` fields the form collects.
// The piercee signature arrives as `signature` (current forms) or the legacy
// `clientSignature` key (older/cached piercing form). Accept either.
const clientSignatureData = b.signature || b.clientSignature || "";

// Photo of the client's driver's license / ID — required on every waiver.
// Sent as a JPEG data URL in `licenseImage`. For a minor piercee the web form
// collects the PARENT/GUARDIAN's ID, so when the guardian section renders the
// image is relocated there instead of the client area (see `showGuardian`),
// mirroring where the interface places the upload.
const licenseImageData = b.licenseImage || "";
const licenseBody = licenseImageData
  ? `<div class="id-wrap"><img class="id-img" src="${licenseImageData}" alt="Driver's License / ID"/></div>`
  : `<div class="sig-missing">Photo ID was not provided.</div>`;
const licenseSection = `
  <h2>Photo Identification</h2>
  ${licenseBody}`;

const hasGuardianSig = !!(b.guardianSignature && b.guardianSignature.trim());

const ageFromDob = (() => {
  const raw = (b.dob || "").trim();
  if (!raw) return null;
  const born = new Date(raw.length === 10 ? raw + "T00:00:00" : raw);
  const ref = new Date(signDate.length === 10 ? signDate + "T00:00:00" : signDate);
  if (isNaN(born) || isNaN(ref)) return null;
  let a = ref.getFullYear() - born.getFullYear();
  const m = ref.getMonth() - born.getMonth();
  if (m < 0 || (m === 0 && ref.getDate() < born.getDate())) a--;
  return a;
})();
const declaredAge = parseInt(b.minorAge || b.age, 10);
const isMinor =
  (ageFromDob != null && ageFromDob >= 0 && ageFromDob < 18) ||
  (!isNaN(declaredAge) && declaredAge >= 0 && declaredAge < 18);

// Guardian section — rendered for piercing minors, or any time a guardian
// signed. Omitted entirely for adult (18+) clients and for tattoo forms.
const showGuardian = isPiercing && (hasGuardianSig || isMinor);

const guardianSigInk = hasGuardianSig
  ? `<img src="${b.guardianSignature}" alt="Parent/Guardian Signature"/>`
  : `<div class="sig-missing">Parent/Guardian signature was not captured.</div>`;

const guardianSigBlock = showGuardian
  ? `
  <h2>Parent/Guardian (Minor Piercee)</h2>
  <div class="grid">
    ${cell("Minor's Age", b.minorAge || b.age)}
    ${cell("Guardian Name", b.guardianName)}
    ${cell("Relationship", b.guardianRelationship)}
    ${cell("Guardian Phone", b.guardianPhone)}
    ${cell("Guardian Email", b.guardianEmail)}
    ${cell("Guardian Address", guardianAddressLine, true)}
  </div>
  <h2>Parent/Guardian Photo Identification</h2>
  ${licenseBody}
  <div class="sig-wrap">
    <div class="sig-box">
      ${guardianSigInk}
      <div class="sig-line">${b.guardianName || "Parent/Guardian"}</div>
    </div>
    <div class="sig-meta">
      <div><b>Signed:</b> ${fmt(b.guardianSignDate || signDate)}</div>
    </div>
    ${guardianConsent}
  </div>`
  : "";

const LOGO =
  "data:image/png;base64,";

const html = `<!doctype html><html lang="en"><head><meta charset="utf-8">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600;700&family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;700&display=swap');
  @page { size: Letter; margin: 40px 46px; }
  * { box-sizing: border-box; }
  body { font-family: 'DM Sans', Arial, sans-serif; color: #1c1a17; font-size: 11.5px; line-height: 1.5; margin: 0; }
  .doc { max-width: 720px; margin: 0 auto; }

  header { text-align: center; padding-bottom: 14px; border-bottom: 2px solid #C4A982; }
  header img { width: 230px; height: auto; margin: 0 auto 6px; display: block; }

  .kicker { text-align: center; text-transform: uppercase; letter-spacing: .28em; font-size: 9px; color: #C4A982; font-weight: 700; margin: 18px 0 6px; }
  h1 { font-family: 'Playfair Display', Georgia, serif; font-weight: 700; font-size: 21px; text-align: center; margin: 0 0 22px; color: #14120f; }

  h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 14px; font-weight: 600; margin: 22px 0 10px; padding-bottom: 5px; border-bottom: 1px solid #ece6da; color: #14120f; }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 28px; }
  .cell { border-bottom: 1px solid #f0ebe2; padding: 4px 0; }
  .cell.full { grid-column: 1 / -1; }
  .lbl { display: block; text-transform: uppercase; letter-spacing: .1em; font-size: 8px; color: #9a8f7d; font-weight: 700; }
  .val { display: block; font-size: 12px; color: #221f1a; }

  ol.provs { list-style: none; padding: 0; margin: 0; counter-reset: none; }
  .prov { display: grid; grid-template-columns: 22px 1fr 46px; gap: 10px; align-items: start; padding: 7px 0; border-bottom: 1px solid #f3eee5; }
  .prov-num { font-family: 'Playfair Display', Georgia, serif; color: #C4A982; font-size: 13px; font-weight: 700; text-align: center; }
  .prov-text { font-size: 10.5px; color: #34302a; }
  .prov-badge { font-size: 9px; font-weight: 700; text-align: center; padding: 3px 0; border-radius: 4px; height: fit-content; }
  .prov-badge.ok { font-family: 'Dancing Script', 'Segoe Script', cursive; font-size: 16px; line-height: 1; background: #f3ecdd; color: #7a6636; border: 1px solid #e3d6b8; }
  .prov-badge.no { background: #f6f6f6; color: #b3b3b3; border: 1px solid #eee; }

  .sig-wrap { margin-top: 8px; }
  .sig-box { border: 1px solid #e7e0d3; border-radius: 8px; padding: 14px 18px 8px; background: #fffdf9; display: inline-block; min-width: 320px; }
  /* Signature was drawn in a light color for the dark form; invert to dark ink for print */
  .sig-box img { max-width: 300px; height: auto; filter: invert(1) contrast(1.15); }
  .sig-line { border-top: 1px solid #cfc6b4; margin-top: 4px; padding-top: 6px; font-size: 10px; color: #6a6256; }
  .sig-missing { min-width: 260px; padding: 22px 0; font-size: 11px; font-style: italic; color: #b3675e; }

  .id-wrap { margin-top: 8px; }
  .id-img { max-width: 340px; max-height: 230px; height: auto; border: 1px solid #e7e0d3; border-radius: 8px; background: #fffdf9; padding: 6px; }
  .sig-meta { margin-top: 10px; font-size: 10.5px; }
  .sig-meta b { color: #14120f; }

  .consent { margin-top: 12px; font-size: 9.5px; color: #726a5c; background: #faf7f1; border: 1px solid #efe8db; border-radius: 6px; padding: 8px 10px; }

  footer { margin-top: 26px; padding-top: 12px; border-top: 2px solid #C4A982; display: flex; justify-content: space-between; align-items: center; font-size: 9px; color: #8a8172; }
  footer .verse { font-family: 'Playfair Display', Georgia, serif; font-style: italic; color: #a8987b; }

  /* Let the document flow to as few pages as the content needs; only keep
     logical blocks (a provision row, the ID photo, the signature) from
     splitting across a page boundary. */
  .prov, .id-wrap, .sig-wrap { page-break-inside: avoid; break-inside: avoid; }
  /* Tattoo waiver only: force the signature onto its own fresh page. */
  .page-break { page-break-before: always; break-before: page; }
</style></head>
<body><div class="doc">

  <header><img src="${LOGO}" alt="WayMaker Ink"/></header>

  <p class="kicker">Waiver, Release &amp; Consent to ${isPiercing ? "Pierce" : "Tattoo"}</p>
  <h1>${isPiercing ? "Piercing" : "Tattoo"} Waiver &amp; Release</h1>

  <h2>Client Information</h2>
  <div class="grid">${clientCells}</div>
  ${procedureSection}

  <h2>Provisions Initialed</h2>
  <ol class="provs">${provisionRows}</ol>

  ${showGuardian ? "" : licenseSection}

  <h2${isPiercing ? "" : ' class="page-break"'}>Signature</h2>
  <div class="sig-wrap">
    <div class="sig-box">
      <img src="${clientSignatureData}" alt="Signature"/>
      <div class="sig-line">${fullName}</div>
    </div>
    <div class="sig-meta">
      <div><b>Signed:</b> ${fmt(signDate)}</div>
      <div><b>Timestamp:</b> ${signedAt}</div>
    </div>
    <div class="consent">${consentLine}</div>
  </div>

  ${guardianSigBlock}

  <footer>
    <span>&copy; ${new Date().getFullYear()} WayMaker Ink LLC</span>
    <span class="verse">&ldquo;I am the way, the truth, and the life.&rdquo; &mdash; John 14:6</span>
  </footer>

</div></body></html>`;

return {
  json: {
    firstInitial,
    lastInitial,
    initials,
    lastNameClean,
    folderName,
    fullName,
    addressLine,
    formType,
    signDate,
    signedAt,
    fileName,
    html,
    ...b,
  },
};
